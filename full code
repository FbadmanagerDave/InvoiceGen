<!-- TOAST -->
<div class="tsw-toast" id="tsw-toast"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script>
(function() {
'use strict';

/* ─── CURRENCY ─── */
const CURRENCIES = {
  USD: { symbol: '$',    pdfSymbol: '$',    code: 'USD' },
  EUR: { symbol: '€',    pdfSymbol: 'EUR ', code: 'EUR' },
  GBP: { symbol: '£',    pdfSymbol: 'GBP ', code: 'GBP' },
  CAD: { symbol: 'C$',   pdfSymbol: 'C$',   code: 'CAD' },
  INR: { symbol: '₹',    pdfSymbol: 'INR ', code: 'INR' },
  AUD: { symbol: 'A$',   pdfSymbol: 'A$',   code: 'AUD' },
  CHF: { symbol: 'CHF ', pdfSymbol: 'CHF ', code: 'CHF' },
  JPY: { symbol: '¥',    pdfSymbol: 'JPY ', code: 'JPY' },
};
function getCurrency() {
  return CURRENCIES[document.getElementById('tsw-currency').value] || CURRENCIES.USD;
}
function formatMoney(n) {
  const cur = getCurrency();
  if (cur.code === 'JPY') return cur.symbol + Math.round(n).toLocaleString('en-US');
  return cur.symbol + parseFloat(n||0).toLocaleString('en-US', { minimumFractionDigits:2, maximumFractionDigits:2 });
}
function pdfMoney(n) {
  const cur = getCurrency();
  if (cur.code === 'JPY') return cur.pdfSymbol + Math.round(n).toLocaleString('en-US');
  return cur.pdfSymbol + parseFloat(n||0).toLocaleString('en-US', { minimumFractionDigits:2, maximumFractionDigits:2 });
}
function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function todayStr() { return new Date().toISOString().split('T')[0]; }

/* ─── STATE ─── */
let rows = [{ desc: 'Service / Product Description', qty: 1, rate: 100 }];
let currentStatus = 'draft';
let toastTimer;

/* ─── TOAST ─── */
function showToast(msg) {
  const el = document.getElementById('tsw-toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

/* ─── RENDER ROWS ─── */
function renderRows() {
  const tbody = document.getElementById('tsw-rows');
  tbody.innerHTML = '';
  rows.forEach((row, i) => {
    const total = (parseFloat(row.qty)||0) * (parseFloat(row.rate)||0);
    const tr = document.createElement('tr');
    tr.innerHTML =
      `<td><input class="tsw-cell-input desc" data-i="${i}" data-f="desc" value="${escHtml(row.desc)}" placeholder="Item description"/></td>` +
      `<td><input class="tsw-cell-input num"  data-i="${i}" data-f="qty"  value="${row.qty}"  placeholder="1"    type="number" min="0" step="any"/></td>` +
      `<td><input class="tsw-cell-input num"  data-i="${i}" data-f="rate" value="${row.rate}" placeholder="0.00" type="number" min="0" step="any"/></td>` +
      `<td class="tsw-line-total">${formatMoney(total)}</td>` +
      `<td class="tsw-row-delete tsw-no-print"><button class="tsw-delete-btn" data-i="${i}" title="Remove">\u00d7</button></td>`;
    tbody.appendChild(tr);
  });
  updateTotals();
}

/* ─── UPDATE TOTALS ─── */
function updateTotals() {
  const subtotal = rows.reduce((s,r) => s + (parseFloat(r.qty)||0)*(parseFloat(r.rate)||0), 0);
  const taxRate  = parseFloat(document.getElementById('tsw-tax').value)      || 0;
  const discRate = parseFloat(document.getElementById('tsw-discount').value) || 0;
  const taxAmt   = subtotal * (taxRate  / 100);
  const discAmt  = subtotal * (discRate / 100);
  const total    = subtotal + taxAmt - discAmt;
  document.getElementById('tsw-subtotal').textContent = formatMoney(subtotal);
  document.getElementById('tsw-total').textContent    = formatMoney(total);
  const bd = document.getElementById('tsw-breakdown');
  let bdHtml = '';
  if (taxAmt  > 0) bdHtml += `<div class="tsw-breakdown-row"><span>Tax (${taxRate}%)</span><span>+${formatMoney(taxAmt)}</span></div>`;
  if (discAmt > 0) bdHtml += `<div class="tsw-breakdown-row"><span>Discount (${discRate}%)</span><span>-${formatMoney(discAmt)}</span></div>`;
  bd.innerHTML = bdHtml;
}

/* ─── ROW EVENTS ─── */
document.getElementById('tsw-rows').addEventListener('input', e => {
  const el = e.target, i = parseInt(el.dataset.i), f = el.dataset.f;
  if (isNaN(i) || !f) return;
  rows[i][f] = el.value;
  if (f === 'qty' || f === 'rate') {
    const t = (parseFloat(rows[i].qty)||0) * (parseFloat(rows[i].rate)||0);
    el.closest('tr').querySelector('.tsw-line-total').textContent = formatMoney(t);
    updateTotals();
  }
});

document.getElementById('tsw-rows').addEventListener('click', e => {
  const btn = e.target.closest('.tsw-delete-btn');
  if (!btn) return;
  const i = parseInt(btn.dataset.i);
  if (rows.length === 1) { showToast('⚠️ At least one line item is required'); return; }
  rows.splice(i, 1);
  renderRows();
});

document.getElementById('tsw-add-row').addEventListener('click', () => {
  rows.push({ desc: '', qty: 1, rate: 0 });
  renderRows();
  setTimeout(() => {
    const inputs = document.querySelectorAll('#tsw-rows .tsw-cell-input.desc');
    if (inputs.length) inputs[inputs.length - 1].focus();
  }, 50);
});

['tsw-tax','tsw-discount','tsw-currency'].forEach(id => {
  document.getElementById(id).addEventListener('input',  () => renderRows());
  document.getElementById(id).addEventListener('change', () => renderRows());
});

/* ─── LOGO UPLOAD ─── */
document.getElementById('tsw-logo-input').addEventListener('change', e => {
  const file = e.target.files[0];
  if (!file || !file.type.startsWith('image/')) return;
  const reader = new FileReader();
  reader.onload = () => {
    const img = document.getElementById('tsw-logo-img');
    img.src = reader.result;
    img.style.display = 'block';
    document.getElementById('tsw-logo-drop').style.display = 'none';
  };
  reader.readAsDataURL(file);
});

/* ─── STATUS PILLS ─── */
['draft','pending','paid'].forEach(s => {
  document.getElementById(`tsw-status-${s}`).addEventListener('click', () => {
    currentStatus = s;
    ['draft','pending','paid'].forEach(x => {
      document.getElementById(`tsw-status-${x}`).style.fontWeight = x === s ? '700' : '500';
      document.getElementById(`tsw-status-${x}`).style.boxShadow  = x === s ? '0 2px 8px rgba(0,0,0,0.12)' : 'none';
    });
    document.getElementById('tsw-paid-stamp').classList.toggle('visible', s === 'paid');
    showToast(s==='paid' ? '✅ Marked as Paid' : s==='pending' ? '🕐 Marked as Pending' : '📝 Set to Draft');
  });
});

/* ─── PRINT ─── */
document.getElementById('tsw-print-btn').addEventListener('click', () => window.print());

/* ─── NEW INVOICE ─── */
document.getElementById('tsw-clear-btn').addEventListener('click', () => {
  if (!confirm('Start a new invoice? Unsaved changes will be lost.')) return;
  rows = [{ desc: '', qty: 1, rate: 0 }];
  document.getElementById('tsw-company-name').value    = 'Your Company Name';
  document.getElementById('tsw-company-address').value = 'Street Address\nCity, ZIP\nPhone | Email';
  document.getElementById('tsw-bill-from').value  = '';
  document.getElementById('tsw-bill-to').value    = '';
  document.getElementById('tsw-notes').value      = '';
  document.getElementById('tsw-inv-number').value = 'INV-001';
  document.getElementById('tsw-tax').value        = '0';
  document.getElementById('tsw-discount').value   = '0';
  document.getElementById('tsw-terms').value      = '';
  document.getElementById('tsw-inv-date').value   = todayStr();
  document.getElementById('tsw-inv-due').value    = '';
  document.getElementById('tsw-logo-img').style.display  = 'none';
  document.getElementById('tsw-logo-drop').style.display = '';
  document.getElementById('tsw-paid-stamp').classList.remove('visible');
  currentStatus = 'draft';
  renderRows();
  showToast('🆕 New invoice started');
});

/* ─── SAVE / LOAD ─── */
document.getElementById('tsw-save-btn').addEventListener('click', () => {
  try {
    localStorage.setItem('tsw_invoice_draft', JSON.stringify({
      companyName: document.getElementById('tsw-company-name').value,
      companyAddr: document.getElementById('tsw-company-address').value,
      billFrom:    document.getElementById('tsw-bill-from').value,
      billTo:      document.getElementById('tsw-bill-to').value,
      invNumber:   document.getElementById('tsw-inv-number').value,
      invDate:     document.getElementById('tsw-inv-date').value,
      invDue:      document.getElementById('tsw-inv-due').value,
      currency:    document.getElementById('tsw-currency').value,
      terms:       document.getElementById('tsw-terms').value,
      tax:         document.getElementById('tsw-tax').value,
      discount:    document.getElementById('tsw-discount').value,
      notes:       document.getElementById('tsw-notes').value,
      rows, status: currentStatus,
      logoSrc: document.getElementById('tsw-logo-img').src
    }));
    showToast('💾 Draft saved successfully');
  } catch(e) { showToast('⚠️ Could not save'); }
});

document.getElementById('tsw-load-btn').addEventListener('click', () => {
  try {
    const raw = localStorage.getItem('tsw_invoice_draft');
    if (!raw) { showToast('⚠️ No saved draft found'); return; }
    const d = JSON.parse(raw);
    document.getElementById('tsw-company-name').value    = d.companyName || '';
    document.getElementById('tsw-company-address').value = d.companyAddr || '';
    document.getElementById('tsw-bill-from').value  = d.billFrom  || '';
    document.getElementById('tsw-bill-to').value    = d.billTo    || '';
    document.getElementById('tsw-inv-number').value = d.invNumber || '';
    document.getElementById('tsw-inv-date').value   = d.invDate   || '';
    document.getElementById('tsw-inv-due').value    = d.invDue    || '';
    document.getElementById('tsw-currency').value   = d.currency  || 'USD';
    document.getElementById('tsw-terms').value      = d.terms     || '';
    document.getElementById('tsw-tax').value        = d.tax       || '0';
    document.getElementById('tsw-discount').value   = d.discount  || '0';
    document.getElementById('tsw-notes').value      = d.notes     || '';
    rows = d.rows || [{ desc:'', qty:1, rate:0 }];
    currentStatus = d.status || 'draft';
    if (d.logoSrc && d.logoSrc.startsWith('data:')) {
      const img = document.getElementById('tsw-logo-img');
      img.src = d.logoSrc; img.style.display = 'block';
      document.getElementById('tsw-logo-drop').style.display = 'none';
    }
    document.getElementById('tsw-paid-stamp').classList.toggle('visible', currentStatus==='paid');
    renderRows();
    showToast('📂 Draft loaded successfully');
  } catch(e) { showToast('⚠️ Could not load draft'); }
});

/* ─── PDF ─── */
document.getElementById('tsw-pdf-btn').addEventListener('click', generatePDF);

function generatePDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ unit: 'pt', format: 'a4' });
  const W = doc.internal.pageSize.getWidth();
  const H = doc.internal.pageSize.getHeight();
  const cur = getCurrency();
  const mg = 48;
  let y = 0;

  // Accent bar
  doc.setFillColor(192,57,43); doc.rect(0,0,W,6,'F');
  doc.setFillColor(255,255,255); doc.rect(0,6,W,H-6,'F');
  y = 48;

  // Logo — contained in clean rounded box
  const logoImg = document.getElementById('tsw-logo-img');
  let logoH = 0;
  if (logoImg && logoImg.src && logoImg.src.startsWith('data:')) {
    try {
      const fmt  = logoImg.src.substring(5, logoImg.src.indexOf(';')).split('/')[1].toUpperCase();
      const sfmt = fmt==='JPG' ? 'JPEG' : (['PNG','JPEG','WEBP'].includes(fmt) ? fmt : 'PNG');
      const bw=110, bh=55, nw=logoImg.naturalWidth||110, nh=logoImg.naturalHeight||55;
      const ratio = Math.min(bw/nw, bh/nh);
      const dw=nw*ratio, dh=nh*ratio;
      doc.setFillColor(255,255,255); doc.setDrawColor(229,231,235); doc.setLineWidth(0.5);
      doc.roundedRect(mg, y, bw, bh, 4, 4, 'FD');
      doc.addImage(logoImg.src, sfmt, mg+(bw-dw)/2, y+(bh-dh)/2, dw, dh);
      logoH = bh + 12;
    } catch(e) { logoH = 0; }
  }
  y += logoH;

  // Company name + INVOICE title
  const cName = document.getElementById('tsw-company-name').value || 'Your Company';
  const cAddr = document.getElementById('tsw-company-address').value || '';
  doc.setFont('times','bold'); doc.setFontSize(17); doc.setTextColor(26,26,46);
  doc.text(cName, mg, y);
  doc.setFont('times','bold'); doc.setFontSize(40); doc.setTextColor(26,26,46);
  doc.text('INVOICE', W-mg, 62, { align:'right' });
  y += 17;

  // Company address
  doc.setFont('helvetica','normal'); doc.setFontSize(9.5); doc.setTextColor(107,114,128);
  cAddr.split('\n').slice(0,4).forEach(line => {
    if (line.trim()) { doc.text(line.trim(), mg, y); y += 13; }
  });

  // Meta right side
  const invNum   = document.getElementById('tsw-inv-number').value || 'INV-001';
  const invDate  = document.getElementById('tsw-inv-date').value   || '';
  const invDue   = document.getElementById('tsw-inv-due').value    || '';
  const invTerms = document.getElementById('tsw-terms').value      || '';
  let mY = 76;
  const mx1 = W-mg-160, mx2 = W-mg;
  const metaRows = [['Invoice #', invNum], ['Date', invDate]];
  if (invDue)   metaRows.push(['Due Date', invDue]);
  if (invTerms) metaRows.push(['Terms',    invTerms]);
  metaRows.push(['Currency', cur.code]);
  metaRows.forEach(([label, val]) => {
    doc.setFont('helvetica','normal'); doc.setFontSize(9);   doc.setTextColor(107,114,128); doc.text(label, mx1, mY, {align:'right'});
    doc.setFont('helvetica','bold');   doc.setFontSize(10);  doc.setTextColor(26,26,46);    doc.text(val,   mx2, mY, {align:'right'});
    mY += 16;
  });

  // Status badge
  if (currentStatus !== 'draft') {
    const sc = currentStatus==='paid' ? [5,150,105] : [217,119,6];
    doc.setFillColor(sc[0],sc[1],sc[2]);
    doc.roundedRect(W-mg-52, mY, 52, 18, 4, 4, 'F');
    doc.setFont('helvetica','bold'); doc.setFontSize(8); doc.setTextColor(255,255,255);
    doc.text(currentStatus.toUpperCase(), W-mg-26, mY+11.5, {align:'center'});
  }
  y = Math.max(y, mY) + 24;

  // Divider
  doc.setDrawColor(229,231,235); doc.setLineWidth(1); doc.line(mg, y, W-mg, y); y += 22;

  // Bill From / To
  const bFrom = document.getElementById('tsw-bill-from').value || '';
  const bTo   = document.getElementById('tsw-bill-to').value   || '';
  const cw = (W - mg*2) / 2 - 16;
  ['BILL FROM','BILL TO'].forEach((lbl, idx) => {
    doc.setFont('helvetica','bold'); doc.setFontSize(7.5); doc.setTextColor(192,57,43);
    doc.text(lbl, mg + idx*(cw+32), y);
  });
  y += 14;
  const fl = bFrom.split('\n'), tl = bTo.split('\n');
  const ml = Math.max(fl.length, tl.length, 1);
  for (let i=0; i<ml; i++) {
    doc.setFont('helvetica','normal'); doc.setFontSize(10); doc.setTextColor(17,24,39);
    if (fl[i] && fl[i].trim()) doc.text(fl[i].trim(), mg,       y);
    if (tl[i] && tl[i].trim()) doc.text(tl[i].trim(), mg+cw+32, y);
    y += 14;
  }
  y += 20;

  // Table header
  const cd=mg+14, cq=W-mg-260, cr=W-mg-150, ca=W-mg-10;
  doc.setFillColor(26,26,46); doc.roundedRect(mg, y, W-mg*2, 28, 4, 4, 'F');
  doc.setFont('helvetica','bold'); doc.setFontSize(8.5); doc.setTextColor(255,255,255);
  doc.text('DESCRIPTION', cd, y+18);
  doc.text('QTY',    cq, y+18, {align:'right'});
  doc.text('RATE',   cr, y+18, {align:'right'});
  doc.text('AMOUNT', ca, y+18, {align:'right'});
  y += 36;

  // Line item rows
  rows.forEach((row, idx) => {
    const lt = (parseFloat(row.qty)||0) * (parseFloat(row.rate)||0);
    if (idx%2===1) { doc.setFillColor(248,249,250); doc.rect(mg, y-7, W-mg*2, 24, 'F'); }
    doc.setFont('helvetica','normal'); doc.setFontSize(10); doc.setTextColor(17,24,39);
    const dtxt = doc.splitTextToSize(row.desc||'', cq-cd-10);
    doc.text(dtxt[0]||'', cd, y+9);
    doc.setTextColor(55,65,81);
    doc.text(String(row.qty||''), cq, y+9, {align:'right'});
    doc.text(pdfMoney(row.rate),  cr, y+9, {align:'right'});
    doc.setFont('helvetica','bold'); doc.setTextColor(17,24,39);
    doc.text(pdfMoney(lt), ca, y+9, {align:'right'});
    y += 24;
    if (y > H-180) { doc.addPage(); y=48; }
  });

  // Subtotal rows
  y += 10;
  doc.setDrawColor(229,231,235); doc.setLineWidth(0.75); doc.line(mg, y, W-mg, y); y += 18;
  const sub  = rows.reduce((s,r) => s+(parseFloat(r.qty)||0)*(parseFloat(r.rate)||0), 0);
  const txR  = parseFloat(document.getElementById('tsw-tax').value)      || 0;
  const dcR  = parseFloat(document.getElementById('tsw-discount').value) || 0;
  const txA  = sub*(txR/100), dcA=sub*(dcR/100), tot=sub+txA-dcA;
  const tlx  = W-mg-130, tvx=W-mg;
  const totRows = [['Subtotal', pdfMoney(sub)]];
  if (txA>0) totRows.push([`Tax (${txR}%)`,      '+'+pdfMoney(txA)]);
  if (dcA>0) totRows.push([`Discount (${dcR}%)`, '-'+pdfMoney(dcA)]);
  totRows.forEach(([label, val]) => {
    doc.setFont('helvetica','normal'); doc.setFontSize(10); doc.setTextColor(107,114,128); doc.text(label, tlx, y, {align:'right'});
    doc.setTextColor(55,65,81); doc.text(val, tvx, y, {align:'right'});
    y += 18;
  });

  // Total box — full width, no clipping
  y += 6;
  doc.setFillColor(26,26,46); doc.roundedRect(mg, y-13, W-mg*2, 36, 6, 6, 'F');
  doc.setFont('times','bold'); doc.setFontSize(13); doc.setTextColor(255,255,255);
  doc.text('TOTAL', mg+18, y+11);
  doc.setFontSize(18);
  doc.text(pdfMoney(tot), W-mg-14, y+11, {align:'right'});
  y += 48;

  // Notes
  const notes = document.getElementById('tsw-notes').value.trim();
  if (notes) {
    doc.setDrawColor(229,231,235); doc.setLineWidth(1); doc.line(mg, y, W-mg, y); y += 16;
    doc.setFont('helvetica','bold'); doc.setFontSize(7.5); doc.setTextColor(192,57,43);
    doc.text('NOTES & PAYMENT DETAILS', mg, y); y += 14;
    doc.setFont('helvetica','normal'); doc.setFontSize(10); doc.setTextColor(55,65,81);
    doc.splitTextToSize(notes, W-mg*2).forEach(line => { doc.text(line, mg, y); y += 14; });
  }

  // PAID watermark
  if (currentStatus === 'paid') {
    try {
      doc.setFont('helvetica','bold'); doc.setFontSize(80); doc.setTextColor(5,150,105);
      doc.setGState(new doc.GState({ opacity: 0.12 }));
      doc.text('PAID', W/2, H/2+20, { align:'center', angle:22 });
      doc.setGState(new doc.GState({ opacity: 1 }));
    } catch(e) {}
  }

  // Footer
  doc.setFont('helvetica','normal'); doc.setFontSize(8); doc.setTextColor(156,163,175);
  doc.text('Generated with The Story Watch Invoice Generator \xb7 thestorywatch.com', W/2, H-24, {align:'center'});

  const fn = document.getElementById('tsw-inv-number').value || 'invoice';
  doc.save(fn + '.pdf');
  showToast('✅ PDF downloaded successfully');
}

/* ─── INIT ─── */
document.getElementById('tsw-inv-date').value = todayStr();
const due = new Date(); due.setDate(due.getDate() + 30);
document.getElementById('tsw-inv-due').value = due.toISOString().split('T')[0];
renderRows();

})();
</script>
