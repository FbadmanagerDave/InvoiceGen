            <input class="tsw-totals-input" id="tsw-tax" type="number" value="0" min="0" max="100" step="0.1"/>
          </div>
          <div class="tsw-totals-row">
            <span class="tsw-totals-label">Discount (%)</span>
            <input class="tsw-totals-input" id="tsw-discount" type="number" value="0" min="0" max="100" step="0.1"/>
